  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import os\r\nimport sys\r\nimport importlib\r\nfrom Dynamo.Applications import DynamoRevit\r\nres = list()\r\nworkspace = DynamoRevit().RevitDynamoModel.CurrentWorkspace\r\n\r\nfull_path = workspace.FileName\r\nfile_name = os.path.splitext(os.path.basename(full_path))[0]\r\ncurrent_dir = os.path.dirname(full_path)\r\nproject_dir = os.path.join(\r\n    current_dir,\r\n    '%s.files' % file_name\r\n)\r\nsys.path.append(project_dir)\r\n\r\n\r\nmodules_to_reload = (\"lp_models\",)\r\nres = [\r\n    name for name in os.listdir(project_dir)\r\n    if os.path.isdir(os.path.join(project_dir, name))\r\n]\r\n\r\nfor name in list(sys.modules):\r\n    if any(name == m or name.startswith(m + \".\") for m in modules_to_reload):\r\n        del sys.modules[name] \r\n\r\nfor module_name in modules_to_reload:\r\n    break\r\n    importlib.import_module(module_name) \r\n\r\nsource = os.path.join(project_dir, 'main.py')\r\n\r\nwith open(source, 'r', encoding='utf-8') as file:\r\n    code = file.read()\r\n\r\ncode = code.replace(\r\n    \"project_dir: str = None\",\r\n    \"project_dir = r'%s'\" % project_dir\r\n) \r\ncode = code.replace(\r\n    'uiapp = revit.Application if revit else None',\r\n    'uiapp = DocumentManager.Instance.CurrentUIApplication'\r\n)\r\n\r\n\r\n\r\nOUT = code\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "d96d6251d567458f952fa59a5740d3bb",
      "NodeType": "PythonScriptNode",
